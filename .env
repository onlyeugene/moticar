EXPO_PUBLIC_API_URL=http://192.168.100.23:8000/api/v1
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_ACTUAL_KEY_HERE
# moticar_client/.env
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=654675153883-4r2vljo98dbtblpr7p1rd0lbg4p8pc7a.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=654675153883-ta5f6ie2l27ejo8hlbloinafqajr8ptf.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=654675153883-14de3c8km8uus07ogfaqs3u4pe70e9on.apps.googleusercontent.com




# Contentful
EXPO_PUBLIC_CONTENTFUL_SPACE_ID=your_space_id_here
EXPO_PUBLIC_CONTENTFUL_ACCESS_TOKEN=your_access_token_here

eas secret:create --scope project --name EXPO_PUBLIC_API_URL --value "https://api-moticar.onrender.com/api/v1"

eas secret:create --scope project --type string --name EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS --value "654675153883-4r2vljo98dbtblpr7p1rd0lbg4p8pc7a.apps.googleusercontent.com"
eas secret:create --scope project --type string --name EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID --value "654675153883-ta5f6ie2l27ejo8hlbloinafqajr8ptf.apps.googleusercontent.com"
eas secret:create --scope project --type string --name EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB --value "654675153883-14de3c8km8uus07ogfaqs3u4pe70e9on.apps.googleusercontent.com"