{
  "expo": {
    "name": "Moticar",
    "slug": "moticar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/splash.png",
    "scheme": "moticar",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBE74C"
    },
    "ios": {
      "supportsTablet": false,
      "backgroundColor": "#F0F0F0",
      "bundleIdentifier": "com.moticar.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FBE74C",
        "foregroundImage": "./assets/splash.png",
        "backgroundImage": "./assets/splash.png",
        "monochromeImage": "./assets/splash.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.moticar.app"
    },
    "androidStatusBar": {
      "translucent": true,
      "backgroundColor": "#00000000"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      [
        "expo-navigation-bar",
        {
          "position": "relative",
          "barStyle": "light-content",
          "backgroundColor": "#013037"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0aa8a012-aff2-45e1-852d-1a8660566bd8"
      }
    },
    "owner": "moticar",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0aa8a012-aff2-45e1-852d-1a8660566bd8"
    }
  }
}
